{
  "name": "amplifier-agent-ts",
  "version": "0.6.2",
  "description": "TypeScript SDK for the Amplifier agent. Spawns and drives the amplifier-agent Python CLI over a stdio protocol.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "tsx scripts/gen-types.ts",
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "gen:types": "tsx scripts/gen-types.ts",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/amplifier-agent.git",
    "directory": "wrappers/typescript"
  },
  "homepage": "https://github.com/microsoft/amplifier-agent/tree/main/wrappers/typescript#readme",
  "bugs": {
    "url": "https://github.com/microsoft/amplifier-agent/issues"
  },
  "keywords": [
    "amplifier",
    "agent",
    "ai",
    "llm",
    "subprocess",
    "client",
    "sdk"
  ],
  "publishConfig": {
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "json-schema-to-typescript": "^15.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
