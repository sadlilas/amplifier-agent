{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProgressNotification",
  "type": "object",
  "properties": {
    "sessionId": {
      "type": "string"
    },
    "turnId": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "percent": {
      "type": "number"
    }
  },
  "required": [
    "message",
    "sessionId",
    "turnId"
  ],
  "additionalProperties": false,
  "description": "Arbitrary progress update.  ``percent`` is optional (0-100)."
}
